# Secrets
.env
.env.*
!.env.example

# Vercel local state
.vercel

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# Node
node_modules/

# Editor
.DS_Store
*.swp
.idea/
.vscode/

# SQLite transient sidecars (the DB file itself is tracked via R2 pointer, never committed)
*.db-shm
*.db-wal

# DBs — live source-of-truth lives in R2, fetched at build time
data/chabad.db
data/chabad_tracker.db
# ui/public/chabad.db is intentionally TRACKED as a Phase 0 bridge until R2
# wiring lands in Step 3. Remove from tree (and stop tracking) once Vercel's
# prebuild step fetches from R2 by hash. See notes/devlog.md.
# ui/public/chabad.db

# Scratch outputs in data/ — ad-hoc bucket runs, fleet results, cycle payloads
data/*.json
data/*.jsonl
data/*.tsv
data/raw/
data/parsed/

# Build artifacts
/tmp/
*.log
