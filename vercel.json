{
  "buildCommand": "./build.sh",
  "outputDirectory": "ui",
  "framework": null,
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- ui data/chabad.db.url data/chabad.db.sha256 vercel.json build.sh",
  "headers": [
    {
      "source": "/((?!.*\\.[^.]+$).*|.*\\.html)",
      "headers": [
        { "key": "Cache-Control",            "value": "no-store" },
        { "key": "CDN-Cache-Control",        "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    { "source": "/build.json",                 "headers": [{ "key": "Cache-Control", "value": "no-store" },
                                                            { "key": "CDN-Cache-Control", "value": "no-store" },
                                                            { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }] },
    { "source": "/public/chabad.db",           "headers": [{ "key": "Cache-Control", "value": "public, max-age=300" }] },
    { "source": "/public/snapshot.json",       "headers": [{ "key": "Cache-Control", "value": "public, max-age=60"  }] },
    { "source": "/public/quarantine.json",     "headers": [{ "key": "Cache-Control", "value": "public, max-age=60"  }] },
    { "source": "/public/constellations.json", "headers": [{ "key": "Cache-Control", "value": "public, max-age=60"  }] },
    { "source": "/public/feed.json",           "headers": [{ "key": "Cache-Control", "value": "public, max-age=60"  }] },
    { "source": "/public/cycles.jsonl",        "headers": [{ "key": "Cache-Control", "value": "public, max-age=60"  }] }
  ]
}
