{
  "buildCommand": "./build.sh",
  "outputDirectory": "ui",
  "framework": null,
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- ui data/chabad.db.url data/chabad.db.sha256 vercel.json build.sh",
  "headers": [
    { "source": "/public/chabad.db",     "headers": [{ "key": "Cache-Control", "value": "public, max-age=300" }] },
    { "source": "/public/snapshot.json", "headers": [{ "key": "Cache-Control", "value": "public, max-age=60"  }] }
  ]
}
